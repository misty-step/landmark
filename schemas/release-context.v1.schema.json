{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://landmark.dev/schemas/release-context.v1.schema.json",
  "title": "Landmark release context packet",
  "type": "object",
  "additionalProperties": true,
  "x-landmark-artifact": "release context packet",
  "required": ["product", "release", "deterministic", "sources", "classification", "cost", "decision"],
  "properties": {
    "product": { "type": "object" },
    "release": { "type": "object" },
    "deterministic": {
      "type": "object",
      "required": ["commits", "tags", "changed_files", "diff_stats", "manifest", "docs", "package", "prior_releases", "pr_metadata", "release_body", "artifacts"],
      "properties": {
        "commits": { "type": "array", "items": { "type": "object" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "diff_stats": { "type": "array", "items": { "type": "object" } },
        "manifest": { "type": "object" },
        "docs": { "type": "array", "items": { "type": "object" } },
        "package": { "type": ["object", "null"] },
        "prior_releases": { "type": "array", "items": { "type": "string" } },
        "pr_metadata": { "type": "object" },
        "release_body": { "type": "object" },
        "artifacts": { "type": "object" }
      }
    },
    "sources": { "type": "array", "items": { "type": "object" } },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["categories", "significance", "user_visible", "breaking", "security", "migration_heavy", "source", "model", "deterministic_signals", "disagreements", "reasons"],
      "properties": {
        "categories": { "type": "array", "items": { "type": "string" } },
        "significance": { "type": "string" },
        "user_visible": { "type": "boolean" },
        "breaking": { "type": "boolean" },
        "security": { "type": "boolean" },
        "migration_heavy": { "type": "boolean" },
        "source": { "type": "string" },
        "model": { "type": "string" },
        "deterministic_signals": { "type": "array", "items": { "type": "string" } },
        "disagreements": { "type": "array", "items": { "type": "string" } },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "cost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_tokens", "output_tokens", "model_tier", "model", "estimated_usd", "skip", "skip_reason"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "model_tier": { "type": "string" },
        "model": { "type": "string" },
        "estimated_usd": { "type": "number" },
        "skip": { "type": "boolean" },
        "skip_reason": { "type": "string" }
      }
    },
    "decision": { "type": "object", "required": ["action", "reason", "llm_required", "model_tier"] }
  }
}
