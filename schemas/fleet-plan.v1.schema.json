{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://landfall.dev/schemas/fleet-plan.v1.schema.json",
  "title": "Landmark fleet plan",
  "type": "object",
  "additionalProperties": false,
  "x-landfall-artifact": "fleet plan",
  "required": ["generated_at", "source", "summary", "repositories"],
  "properties": {
    "generated_at": { "type": "string" },
    "source": { "type": "string" },
    "summary": { "type": "object", "additionalProperties": { "type": "integer" } },
    "repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repository", "repository_kind", "release_surface", "rank", "default_branch", "recommended_mode", "integration_mode", "integration_rationale", "workflow", "status", "skip_reason", "risk_flags", "required_secrets", "missing_secrets", "unavailable_secret_metadata", "migration_notes", "manifest"],
        "properties": {
          "repository": { "type": "string" },
          "repository_kind": { "type": "string" },
          "release_surface": { "type": "string" },
          "rank": { "type": "integer" },
          "default_branch": { "type": "string" },
          "recommended_mode": { "type": "string" },
          "integration_mode": { "type": "string" },
          "integration_rationale": { "type": "array", "items": { "type": "string" } },
          "workflow": { "type": "string" },
          "status": { "type": "string" },
          "skip_reason": { "type": "string" },
          "risk_flags": { "type": "array", "items": { "type": "string" } },
          "required_secrets": { "type": "array", "items": { "type": "string" } },
          "missing_secrets": { "type": "array", "items": { "type": "string" } },
          "unavailable_secret_metadata": { "type": "array", "items": { "type": "string" } },
          "migration_notes": { "type": "array", "items": { "type": "string" } },
          "manifest": { "$ref": "landfall-manifest.v1.schema.json" }
        },
        "additionalProperties": false
      }
    }
  }
}
