{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://landmark.dev/schemas/run-evidence.v1.schema.json",
  "title": "Landmark run evidence",
  "type": "object",
  "additionalProperties": false,
  "x-landmark-artifact": "landmark run evidence packet",
  "required": ["provider", "generated_at", "repo_root", "repository", "release_tag", "version", "previous_tag", "source", "technical_changelog_sha256", "notes_sha256", "version_decision", "changed_files", "artifacts", "release_kit", "publication"],
  "properties": {
    "provider": { "type": "string", "enum": ["local", "github"] },
    "generated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "repository": { "type": "string" },
    "release_tag": { "type": "string" },
    "version": { "type": "string" },
    "previous_tag": { "type": "string" },
    "source": { "type": "string" },
    "technical_changelog_sha256": { "type": "string" },
    "notes_sha256": { "type": "string" },
    "version_decision": {
      "type": "object",
      "required": ["latest_tag", "bump", "commit_count", "conventional_commit_count", "range", "decisive_commit", "unknown_commits"],
      "properties": {
        "latest_tag": { "type": "string" },
        "bump": { "type": "string", "enum": ["major", "minor", "patch", "none"] },
        "commit_count": { "type": "integer", "minimum": 0 },
        "conventional_commit_count": { "type": "integer", "minimum": 0 },
        "range": { "type": "string" },
        "decisive_commit": { "type": ["string", "null"] },
        "unknown_commits": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "object",
      "required": ["technical_changelog", "markdown", "plaintext", "html", "json", "rss", "evidence", "release_kit", "release_kit_schema", "release_kit_sha256"],
      "properties": {
        "technical_changelog": { "type": "string" },
        "technical_changelog_audience": { "type": "string" },
        "technical_changelog_schema": { "type": "string" },
        "markdown": { "type": "string" },
        "public_notes_audience": { "type": "string" },
        "public_notes_schema": { "type": "string" },
        "plaintext": { "type": "string" },
        "html": { "type": "string" },
        "json": { "type": "string" },
        "rss": { "type": "string" },
        "evidence": { "type": "string" },
        "release_kit": { "type": "string" },
        "release_kit_schema": { "type": "string", "const": "landmark.release-kit.v1" },
        "release_kit_sha256": { "type": "string" }
      },
      "additionalProperties": false
    },
    "release_kit": { "$ref": "release-kit.v1.schema.json" },
    "publication": {
      "type": "object",
      "required": ["provider", "enabled", "release_body_updated", "release_url", "status"],
      "properties": {
        "provider": { "type": "string" },
        "enabled": { "type": "boolean" },
        "release_body_updated": { "type": "boolean" },
        "release_url": { "type": "string" },
        "status": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
