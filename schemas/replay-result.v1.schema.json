{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://landmark.dev/schemas/replay-result.v1.schema.json",
  "title": "Landmark replay result",
  "type": "object",
  "additionalProperties": false,
  "x-landmark-artifact": "replay-action evidence",
  "required": ["verdict", "scenario_count", "scenarios"],
  "properties": {
    "verdict": { "type": "string", "enum": ["passed", "failed"] },
    "scenario_count": { "type": "integer", "minimum": 0 },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "verdict"],
        "properties": {
          "name": { "type": "string" },
          "verdict": { "type": "string", "enum": ["passed", "failed"] },
          "error": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  }
}
