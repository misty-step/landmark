{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://landfall.dev/schemas/failure-envelope.v1.schema.json",
  "title": "Landmark failure envelope",
  "type": "object",
  "additionalProperties": false,
  "x-landfall-artifact": "--error-format json stderr",
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "stage", "retryable", "user_action", "context"],
      "properties": {
        "code": {
          "type": "string",
          "enum": ["provider_auth", "provider_outage", "invalid_changelog_source", "budget_skip", "synthesis_degradation", "artifact_write_failure", "feed_failure", "publication_mutation_failure", "invalid_input", "command_failed", "internal_error"]
        },
        "stage": { "type": "string" },
        "retryable": { "type": "boolean" },
        "user_action": { "type": "string" },
        "context": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    }
  }
}
