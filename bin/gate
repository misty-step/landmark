#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "${ROOT}"

npm ci --no-fund --no-audit
cargo fmt --check
cargo clippy --locked --all-targets -- -D warnings
cargo test --locked
tag_ref="HEAD"
if git remote get-url origin >/dev/null 2>&1; then
  git fetch --tags --force origin master
  tag_ref="origin/master"
fi
cargo run --locked -- check-version-sync --reference "${tag_ref}"
cargo run --locked -- check-action-contract
cargo run --locked -- setup --repo-root . --output-dir .landfall/setup
cargo run --locked -- replay-action --evidence-dir .landfall/replay
if command -v rustup >/dev/null 2>&1; then
  rustup target add x86_64-unknown-linux-musl
fi
if [ "$(uname -s)" = "Linux" ]; then
  bin/build-linux-action --check
else
  echo "non-Linux host: byte-for-byte Linux action binary parity is enforced by hosted CI"
fi
test -x dist/landfall
shasum -a 256 -c dist/landfall.sha256

if command -v actionlint >/dev/null 2>&1; then
  actionlint
else
  echo "warning: actionlint not found; install actionlint for local workflow lint parity" >&2
fi

git diff --check
