#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "${ROOT}"

npm ci --no-fund --no-audit
cargo fmt --check
cargo clippy --locked --all-targets -- -D warnings
cargo test --locked
ci_event="${LANDMARK_CI_EVENT:-${GITHUB_EVENT_NAME:-}}"
pr_base_sha="${LANDMARK_PR_BASE_SHA:-}"
pr_head_ref="${LANDMARK_PR_HEAD_REF:-${GITHUB_HEAD_REF:-}}"
pr_head_repo="${LANDMARK_PR_HEAD_REPO:-}"
repository="${LANDMARK_REPOSITORY:-${GITHUB_REPOSITORY:-}}"
release_branch="${LANDMARK_RELEASE_BRANCH:-landmark/self-release}"
tag_ref="${LANDMARK_VERSION_REFERENCE:-HEAD}"
candidate_args=()
if [ "${ci_event}" = "pull_request" ] && [ -n "${pr_base_sha}" ]; then
  tag_ref="${pr_base_sha}"
  if [ "${pr_head_ref}" = "${release_branch}" ] && [ "${pr_head_repo}" = "${repository}" ]; then
    candidate_args+=(--allow-release-candidate)
  fi
fi
if git remote get-url origin >/dev/null 2>&1; then
  git fetch --tags --force origin
  if [ "${tag_ref}" = "HEAD" ] && git show-ref --verify --quiet refs/remotes/origin/master; then
    tag_ref="origin/master"
  fi
fi
cargo run --locked -- check-version-sync --reference "${tag_ref}" "${candidate_args[@]}"
cargo run --locked -- check-action-contract
cargo run --locked -- setup --repo-root . --output-dir .landmark/setup
cargo run --locked -- replay-action --evidence-dir .landmark/replay
if command -v rustup >/dev/null 2>&1; then
  rustup target add x86_64-unknown-linux-musl
fi
if [ "$(uname -s)" = "Linux" ]; then
  bin/build-linux-action --check
else
  echo "non-Linux host: byte-for-byte Linux action binary parity is enforced by hosted CI"
fi
test -x dist/landmark
shasum -a 256 -c dist/landmark.sha256

if command -v actionlint >/dev/null 2>&1; then
  actionlint
else
  echo "warning: actionlint not found; install actionlint for local workflow lint parity" >&2
fi

git diff --check
