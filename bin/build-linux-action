#!/usr/bin/env bash
set -euo pipefail

mode="${1:---check}"
target="x86_64-unknown-linux-musl"
image="rust:1.96-bookworm"

case "$mode" in
  --check|--write) ;;
  *)
    echo "usage: bin/build-linux-action [--check|--write]" >&2
    exit 2
    ;;
esac

linux_command='set -euo pipefail
if ! command -v rustup >/dev/null; then
  curl --proto =https --tlsv1.2 --retry 10 --retry-connrefused --location --silent --show-error --fail https://sh.rustup.rs | sh -s -- --default-toolchain none -y --profile minimal
fi
. /usr/local/cargo/env
rustup toolchain install 1.96.0 --profile minimal --target x86_64-unknown-linux-musl --no-self-update >/dev/null
CARGO_TARGET_DIR=/tmp/landfall-target cargo +1.96.0 build --locked --release --target x86_64-unknown-linux-musl >/dev/null
built=/tmp/landfall-target/x86_64-unknown-linux-musl/release/landfall
test -x "$built"
if [ "$LANDFALL_DIST_MODE" = "--write" ]; then
  cp "$built" dist/landfall
  sha256sum dist/landfall > dist/landfall.sha256
else
  cmp "$built" dist/landfall
fi'

if [ "$(uname -s)" = "Linux" ]; then
  rustup target add "$target" >/dev/null
  cargo build --locked --release --target "$target" >/dev/null
  built="target/$target/release/landfall"
  test -x "$built"
  if [ "$mode" = "--write" ]; then
    cp "$built" dist/landfall
    sha256sum dist/landfall > dist/landfall.sha256
  else
    cmp "$built" dist/landfall
  fi
else
  command -v docker >/dev/null
  docker run --rm \
    --platform linux/amd64 \
    -e "LANDFALL_DIST_MODE=$mode" \
    -v landfall-rustup-amd64-cache:/usr/local/rustup \
    -v landfall-cargo-amd64-cache:/usr/local/cargo \
    -v "$PWD":/work \
    -w /work \
    "$image" \
    bash -lc "$linux_command"
fi
